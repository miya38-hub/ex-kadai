<div class="container px-5 px-sm-0">
  <div class="row">
    <% if @book&.errors&.any? %>
      <div class="alert alert-danger">
        <h4>
          <%= @book.errors.count %> errors prohibited this obj from being saved:
        </h4>
        <ul>
          <% @book.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    <!-- ===== 左側 User info ===== -->
    <div class="col-md-3">

      <h2>User info</h2>

      <% if @user.profile_image.attached? %>
        <%= image_tag url_for(@user.profile_image),
                      class: "img-fluid",
                      style: "width:100px;height:100px;object-fit:cover;" %>
      <% else %>
        <%= image_tag "no_image.jpg",
                      class: "img-fluid",
                      style: "width:100px;height:100px;" %>
      <% end %>

      <table class="table mt-3">
        <tr>
          <th>name</th>
          <td><%= @user.name %></td>
        </tr>
        <tr>
          <th>introduction</th>
          <td><%= @user.introduction %></td>
        </tr>
      </table>

      <div class="row mb-3">
        <%= link_to edit_user_path(@user),
                    class: "btn btn-outline-secondary w-100" do %>
          <i class="fa-solid fa-user-gear"></i>
        <% end %>
      </div>

      <h2 class="mt-3">New book</h2>

      <%= form_with model: @book, url: books_path, local: true do |f| %>

        <div class="mb-2">
          <%= f.label :title %>
          <%= f.text_field :title, class: "form-control" %>
        </div>

        <div class="mb-2">
          <%= f.label :body %>
          <%= f.text_area :body, class: "form-control" %>
        </div>

        <%= f.submit "Create Book", class: "btn btn-success w-100" %>

      <% end %>

    </div>

    <!-- ===== 右側 Users一覧 ===== -->
    <div class="col-md-8 offset-md-1">
    <% if current_user.present? %>
      <%= render "searches/search" %>
    <% end %>
      <h2>Users</h2>
      
      <div class="d-flex gap-2 mb-3">
        <%= link_to "グループ作成", new_group_path, class: "btn btn-success" %>
        <%= link_to "グループ一覧", groups_path, class: "btn btn-outline-primary" %>
      </div>
      
      <table class="table table-hover table-inverse">
        <thead>
          <tr>
            <th>image</th>
            <th>name</th>
            <th></th>
          </tr>
        </thead>

        <tbody>
          <% @users.each do |user| %>
            <tr>
              <!-- image -->
              <td class="align-middle">
                <%= link_to user_path(user) do %>
                  <% if user.profile_image&.attached? %>
                    <%= image_tag user.profile_image, style: "width:60px;height:60px;object-fit:cover;" %>
                  <% else %>
                    <%= image_tag "no_image.jpg", style: "width:60px;height:60px;object-fit:cover;" %>
                  <% end %>
                <% end %>
              </td>

              <!-- name -->
              <td class="align-middle">
                <%= link_to user.name, user_path(user), class: "text-decoration-none" %>
              </td>

              <!-- follow count -->
              <td class="align-middle text-center">
                <%= link_to user.followings.count, following_user_path(user), class: "text-decoration-none" %>
              </td>

              <!-- follower count -->
              <td class="align-middle text-center">
                <%= link_to user.followers.count, followers_user_path(user), class: "text-decoration-none" %>
              </td>

              <!-- follow button -->
              <td class="align-middle text-center">
                <% if user != current_user %>
                  <% if current_user.following?(user) %>
                    <% rel = current_user.active_relationships.find_by(followed_id: user.id) %>
                    <%= button_to "フォロー解除",
                                  relationship_path(rel),
                                  method: :delete,
                                  class: "btn btn-outline-secondary btn-sm" %>
                  <% else %>
                    <%= button_to "フォロー",
                                  relationships_path(followed_id: user.id),
                                  method: :post,
                                  class: "btn btn-primary btn-sm" %>
                  <% end %>
                <% else %>
                  <span class="text-muted small">自分</span>
                <% end %>
              </td>

              <!-- user's book detail -->
              <td class="align-middle text-center">
                <% latest_book = user.books.order(created_at: :desc).first %>

                <% if latest_book.present? %>
                  <%= link_to "show",
                              book_path(latest_book),
                              class: "btn btn-outline-info btn-sm" %>
                <% else %>
                  <span class="text-muted small">投稿なし</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>

      </table>

    </div>
  </div>
</div>
<%= form_with url: search_path, method: :get, local: true, class: "d-flex gap-2 align-items-center mb-0" do |f| %>
  <%= f.select :range,
    [["User", "User"], ["Book", "Book"]],
    { selected: params[:range] },
    class: "form-select",
    style: "width: 120px;" %>

  <%= f.select :method,
    [["完全一致", "perfect"],
     ["前方一致", "forward"],
     ["後方一致", "backward"],
     ["部分一致", "partial"]],
    { selected: params[:method] },
    class: "form-select",
    style: "width: 140px;" %>

  <%= f.text_field :word,
    value: params[:word],
    placeholder: "キーワードを入力",
    class: "form-control",
    style: "width: 220px;" %>

  <%= f.submit "検索", class: "btn btn-primary" %>
<% end %>